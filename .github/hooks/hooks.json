{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/pre-tool-check.mjs",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/stop-guard.mjs",
        "timeout": 5
      }
    ]
  }
}
