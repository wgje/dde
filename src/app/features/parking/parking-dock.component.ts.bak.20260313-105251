    if (!this.hudDragging()) return;
    if (this.hudDragPointerId !== null && event.pointerId !== this.hudDragPointerId) return;
    this.hudDragging.set(false);
    this.hudDragPointerId = null;
    this.hudDragOffset = null;
    this.persistHudPosition();
  }

  ngOnDestroy(): void {
