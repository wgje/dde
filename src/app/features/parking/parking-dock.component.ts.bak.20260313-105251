    DockDailySlotComponent,
    DockZenModeComponent,
    DockFocusSceneComponent,
    DockPlannerQuickEditComponent,
  ],
  styles: [`
    :host {
      /* 根源修复：不再创建全屏 position:absolute + inset:0 覆盖层。
         原实现：z-50 全屏 absolute 容器，依赖 pointer-events:none 透传点击。
         问题：部分浏览器 / GPU 合成场景下 pointer-events:none 对大面积
               覆盖层 + fixed 子元素的命中检测不一致，导致停泊坞收起后
               下方内容无法点击。
         修复：host 改为 0×0 尺寸，不占据屏幕面积；所有子元素改用
               position:fixed 独立定位，不依赖 host 做布局/堆叠上下文。 */
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 0;
      height: 0;
      overflow: visible;
      pointer-events: none;
    }

    /* ══════════════════════════════════════════
       玻璃拟态基础 — 清新自然系
       ══════════════════════════════════════════ */
    .glass-card {
      background: linear-gradient(165deg, rgba(22, 28, 36, 0.92), rgba(16, 20, 28, 0.88));
      border: 1px solid rgba(148, 163, 184, 0.10);
      box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35),
                  0 2px 8px rgba(0, 0, 0, 0.12),
                  inset 0 0.5px 0 rgba(255, 255, 255, 0.06);
      /* 不使用 backdrop-filter，避免与专注模式全屏 blur 叠加导致 GPU 合成瓶颈 */
      contain: layout style;
      transition:
        border-color var(--pk-overlay-exit) var(--pk-ease-standard),
        box-shadow var(--pk-overlay-exit) var(--pk-ease-standard);
    }
    /* 拖拽任务悬停在坞栏面板时的高亮反馈 */
    .glass-card.drag-receiving {
      border-color: rgba(99, 102, 241, 0.4);
      box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35),
                  0 2px 8px rgba(0, 0, 0, 0.12),
                  0 0 0 1px rgba(99, 102, 241, 0.25),
                  0 0 24px rgba(99, 102, 241, 0.08),
                  inset 0 0.5px 0 rgba(255, 255, 255, 0.06);
    }

    /* ══════════════════════════════════════════
       底部坞栏 — 从底部弹入/滑出
       ══════════════════════════════════════════ */
    .dock-bar {
      pointer-events: auto;
      transition:
        transform var(--pk-panel-enter) var(--pk-ease-enter),
        opacity var(--pk-panel-exit) var(--pk-ease-standard);
      /* vp 缩放保护：停泊坞展开高度不超过视口 55%，防止覆盖主内容 */
      max-height: calc(55dvh - env(safe-area-inset-bottom, 0px));
      overflow: hidden;
      /* 宽度限制：不超过 860px 且不超过内容区宽度（视口 - 侧边栏）再减去左右内边 32px */
      max-width: min(860px, calc(100vw - var(--dock-sidebar-width, 0px) - 32px));
      will-change: transform, opacity;
    }
    .dock-bar.focus-collapsed {
      transform: translateX(-50%) translateY(calc(100% + var(--pk-dist-panel-lift))) scale(0.994);
      opacity: 0;
      pointer-events: none;
    }
    /* 拖拽任务时即使停泊坞未展开，也让坞栏半透明浮起，提供拖放目标提示 */
    .dock-bar.drag-peek {
      transform: translateX(-50%) translateY(var(--pk-dist-panel-peek)) scale(0.997);
      opacity: 0.82;
      pointer-events: auto;
    }
    .dock-bar.focus-expanded {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    /* 专注模式下的背景操作轨：保持可读且显式表明“这是次级操作层”。 */
    .dock-bar.focus-secondary {
      transform: translateX(-50%) translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    .dock-bar.focus-secondary .dock-shell {
      background:
        linear-gradient(180deg, rgba(17, 24, 39, 0.92), rgba(15, 23, 42, 0.88)),
        linear-gradient(120deg, rgba(99, 102, 241, 0.07), transparent 35%);
      border-color: rgba(129, 140, 248, 0.26);
      box-shadow:
        0 16px 40px rgba(2, 6, 23, 0.38),
        0 0 0 1px rgba(129, 140, 248, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .dock-bar.focus-secondary:hover,
    .dock-bar.focus-secondary.drag-receiving {
      transform: translateX(-50%) translateY(0);
    }

    /* ══════════════════════════════════════════
       半圆形停泊坞入口 — 底部中央 · 清新自然系
       ══════════════════════════════════════════ */
    .dock-semicircle {
      position: fixed;
      bottom: 0;
      left: 50%;
      z-index: 51;
      pointer-events: auto;
      cursor: pointer;
      transform:
        translateX(-50%)
        translateY(var(--dock-semicircle-lift, var(--pk-dist-semicircle-lift)))
        scale(var(--dock-semicircle-scale-x, 0.86), var(--dock-semicircle-scale-y, 0.92));
      transform-origin: center bottom;
      width: var(--pk-semicircle-w);
      height: var(--pk-semicircle-h);
      border-radius: 80px 80px 0 0;
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.92));
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-bottom: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      opacity: 0.32;
      transition:
        transform var(--pk-panel-enter) var(--pk-ease-enter),
        opacity var(--pk-panel-exit) var(--pk-ease-standard),
        background-color var(--pk-panel-exit) var(--pk-ease-standard),
        box-shadow var(--pk-panel-exit) var(--pk-ease-standard);
      box-shadow:
        0 -8px 24px rgba(0, 0, 0, 0.24),
        0 -1px 4px rgba(99, 102, 241, 0.08);
    }
    .dock-semicircle:hover {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1, 1);
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.96));
      box-shadow:
        0 -12px 28px rgba(0, 0, 0, 0.3),
        0 -2px 10px rgba(99, 102, 241, 0.14);
    }
    .dock-semicircle.expanded {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1, 1);
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.96), rgba(15, 23, 42, 0.94));
    }
    /* 拖拽悬停反馈：任务块拖过半圆时提供明显的视觉提示 */
    .dock-semicircle.drag-active {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1, 1);
      background: linear-gradient(180deg, rgba(99, 102, 241, 0.25), rgba(30, 41, 59, 0.95));
      box-shadow:
        0 -12px 30px rgba(0, 0, 0, 0.3),
        0 -2px 14px rgba(99, 102, 241, 0.2),
        0 0 0 1px rgba(99, 102, 241, 0.24);
    }
    .dock-semicircle .count-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 16px;
      height: 16px;
      border-radius: 8px;
      background: rgba(99, 102, 241, 0.2);
      color: rgba(165, 180, 252, 0.85);
      font-size: 9px;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      padding: 0 4px;
