    }
    @keyframes semicircleIn {
      0%   { opacity: 0; transform: translateX(-50%) translateY(calc(var(--pk-dist-semicircle-lift) + 6px)) scale(0.94); }
      60%  { opacity: 0.24; transform: translateX(-50%) translateY(max(1px, calc(var(--pk-dist-semicircle-lift) - 4px))) scale(0.985); }
      100% { opacity: 0.32; transform: translateX(-50%) translateY(var(--pk-dist-semicircle-lift)) scale(1); }
    }
    .dock-semicircle-enter {
      animation: semicircleIn var(--pk-panel-enter) var(--pk-ease-enter) both;
    }

    /* ══════════════════════════════════════════
       坞栏卡片 — 悬浮抬升 + 认知负荷侧边色条 · 清新系
       ══════════════════════════════════════════ */
    .dock-card {
      /* 宽度随视口缩放：手机(≤375px)约144px，平板起固定192px */
