{
  "manifest_version": 3,
  "name": "NanoFlow SiYuan Relay",
  "description": "只读转发 NanoFlow 的思源块预览请求，token 仅保存在浏览器扩展本机存储。",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:6806/*",
    "http://localhost:6806/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nanoflow.app/*",
        "https://nanoflow.pages.dev/*",
        "https://dde-eight.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "src/options.html"
}
