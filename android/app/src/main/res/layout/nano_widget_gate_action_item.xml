<?xml version="1.0" encoding="utf-8"?>
<!--
  大门模式：已读 / 完成 按钮 item。渲染时由 Factory 设置：
    - nano_widget_gate_action_icon：图标（eye=已读；check=完成）
    - nano_widget_gate_action_label：按钮文字
  fillInIntent 挂在 root FrameLayout。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:id="@+id/nano_widget_gate_action_slot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/nano_widget_gate_button"
        android:gravity="center"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/nano_widget_gate_action_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:importantForAccessibility="no"
            android:src="@drawable/nano_widget_icon_eye" />

        <TextView
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/nano_widget_gate_action_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#F6FBFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 兼容：保留 chip id 避免旧调用点 NPE -->
        <TextView
            android:id="@+id/nano_widget_action_chip"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
