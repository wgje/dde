<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nano_widget_root_focus"
    android:clipToOutline="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:orientation="horizontal">

            <!-- 2026-04-19：去掉边框背景，保留圆点 + 文字。drawableStart 由 renderer 运行时选择颜色 -->
            <TextView
                android:id="@+id/nano_widget_sync_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:drawableEnd="@drawable/nano_widget_state_dot_green"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text=""
                android:textColor="#4A7A38"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <ListView
            android:id="@+id/nano_widget_content_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:paddingTop="8dp"
            android:paddingBottom="52dp"
            android:scrollbars="none" />
    </LinearLayout>

    <GridView
        android:id="@+id/nano_widget_refresh_list"
        android:layout_width="76dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:columnWidth="76dp"
        android:fadingEdge="none"
        android:horizontalSpacing="0dp"
        android:numColumns="1"
        android:overScrollMode="never"
        android:requiresFadingEdge="none"
        android:scrollbars="none"
        android:stretchMode="none"
        android:verticalSpacing="0dp" />
</FrameLayout>
