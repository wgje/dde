<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_widget_focus_action_root"
    android:layout_width="match_parent"
    android:layout_height="34dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <LinearLayout
        android:id="@+id/nano_widget_focus_action_slot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/nano_widget_gate_button"
        android:gravity="center"
        android:minHeight="28dp"
        android:orientation="horizontal"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <ImageView
            android:id="@+id/nano_widget_focus_action_icon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center_vertical"
            android:importantForAccessibility="no"
            android:src="@drawable/nano_widget_icon_clock" />

        <TextView
            android:id="@+id/nano_widget_focus_action_gap"
            android:layout_width="4dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/nano_widget_focus_action_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#F6FBFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
