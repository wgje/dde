<?xml version="1.0" encoding="utf-8"?>
<!-- 小尺寸小组件（SMALL/MEDIUM 共用）：单一点击 = 打开 App，不含 chip/分页/refresh -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nano_widget_root_focus"
    android:clipToOutline="true"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/nano_widget_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#BFD7FF"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="4dp" />

        <TextView
            android:id="@+id/nano_widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="3"
            android:text=""
            android:textColor="#F6FBFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="4dp" />

        <TextView
            android:id="@+id/nano_widget_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text=""
            android:textColor="#D7E5FF"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
