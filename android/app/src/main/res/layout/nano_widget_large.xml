<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nano_widget_root_focus"
    android:clipToOutline="true"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!-- 顶行：左 sync_badge | spacer | 右 tab_list（横排） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">
            <!-- 2026-04-19：去掉 chip_surface 边框，改为圆点 + 文字；drawableStart 由 renderer 根据 tone 动态换色 -->
            <TextView
                android:id="@+id/nano_widget_sync_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:drawableStart="@drawable/nano_widget_state_dot_green"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text=""
                android:textColor="#4A7A38"
                android:textSize="11sp"
                android:visibility="gone" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:text="" />
            <!-- 2026-04-19：禁用 tab_list 上下滑动视觉反馈（scrollbars/overScroll/edge fading 全关） -->
            <GridView
                android:id="@+id/nano_widget_tab_list"
                android:layout_width="82dp"
                android:layout_height="60dp"
                android:columnWidth="82dp"
                android:fadingEdge="none"
                android:horizontalSpacing="4dp"
                android:numColumns="1"
                android:overScrollMode="never"
                android:requiresFadingEdge="none"
                android:scrollbars="none"
                android:stretchMode="none"
                android:verticalSpacing="0dp" />
        </LinearLayout>

        <!-- 中央：标题 + 副标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">
            <TextView
                android:id="@+id/nano_widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="3"
                android:text=""
                android:textColor="#1F2A17"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="4dp" />
            <TextView
                android:id="@+id/nano_widget_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text=""
                android:textColor="#5E7050"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 底行：左 metrics | spacer | 右 refresh_list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/nano_widget_metrics_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text=""
                android:textColor="#5E7050"
                android:textSize="11sp"
                android:visibility="gone" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:text="" />
            <!-- 2026-04-19：refresh_list 同步禁用滑动视觉反馈 -->
            <GridView
                android:id="@+id/nano_widget_refresh_list"
                android:layout_width="82dp"
                android:layout_height="60dp"
                android:columnWidth="82dp"
                android:fadingEdge="none"
                android:horizontalSpacing="0dp"
                android:numColumns="1"
                android:overScrollMode="never"
                android:requiresFadingEdge="none"
                android:scrollbars="none"
                android:stretchMode="none"
                android:verticalSpacing="0dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>