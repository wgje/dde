<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nano_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nano_widget_root_focus"
    android:clipToOutline="true"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!-- 顶行：左 sync_badge | spacer | 右 tab_list（横排） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/nano_widget_sync_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text=""
                android:textColor="#4A7A38"
                android:textSize="11sp"
                android:visibility="gone" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:text="" />
            <GridView
                android:id="@+id/nano_widget_tab_list"
                android:layout_width="254dp"
                android:layout_height="48dp"
                android:horizontalSpacing="4dp"
                android:verticalSpacing="0dp"
                android:numColumns="1"
                android:columnWidth="82dp"
                android:stretchMode="none" />
        </LinearLayout>

        <ListView
            android:id="@+id/nano_widget_content_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:scrollbars="none" />

        <!-- 底行：左 metrics | spacer | 右 refresh_list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/nano_widget_metrics_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text=""
                android:textColor="#5E7050"
                android:textSize="11sp"
                android:visibility="gone" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:text="" />
            <GridView
                android:id="@+id/nano_widget_refresh_list"
                android:layout_width="82dp"
                android:layout_height="48dp"
                android:horizontalSpacing="0dp"
                android:verticalSpacing="0dp"
                android:numColumns="1"
                android:columnWidth="82dp"
                android:stretchMode="none" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>