<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      TWA 宿主的 post-splash 主题。
      2026-04-19：继承 Theme.SplashScreen.IconBackground 以在 Android 12+ 上复用系统
      splash 的 icon 背景色字段，保证 post-splash 阶段的 window 背景、状态栏和导航栏颜色
      与 initial-loader 使用的 #F9F8F6 一致，避免 ABH 从 LauncherActivity 切换到 Chrome
      之间露出白帧。
    -->
    <style name="Theme.NanoFlow.Twa" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/nanoflow_twa_post_splash</item>
        <item name="android:colorBackground">@color/nanoflow_twa_launch_background</item>
        <item name="android:statusBarColor">@color/nanoflow_twa_launch_background</item>
        <item name="android:navigationBarColor">@color/nanoflow_twa_launch_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!--
      LauncherActivity 启动主题。
      2026-04-19：补上 windowSplashScreenIconBackgroundColor，让 Android 12+ 系统 splash 的
      icon 圆形底与主背景一致；否则在白色 icon padding 区域会出现"中央 logo + 四周白底"的
      闪白观感。
    -->
    <style name="Theme.NanoFlow.Twa.Launcher" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/nanoflow_twa_launch_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/nanoflow_launcher_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/nanoflow_twa_launch_background</item>
        <item name="postSplashScreenTheme">@style/Theme.NanoFlow.Twa</item>
    </style>

    <!-- 小组件按钮透明执行页：承接已读/完成动作，不显示可感知 UI。 -->
    <style name="Theme.NanoFlow.WidgetAction" parent="@android:style/Theme.Translucent.NoTitleBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
