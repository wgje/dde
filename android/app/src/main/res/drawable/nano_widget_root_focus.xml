<?xml version="1.0" encoding="utf-8"?>
<!-- Focus 根背景：深钴蓝蓝图底 + 技术网格 + 白色描边。 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#082B60" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:drawable="@drawable/nano_widget_blueprint_grid" />
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#D8FFFFFF" />
        </shape>
    </item>
</layer-list>
