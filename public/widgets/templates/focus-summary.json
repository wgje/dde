{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "专注任务",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${focusTaskName}",
              "wrap": true,
              "maxLines": 2
            }
          ]
        }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "1",
          "items": [
            {
              "type": "TextBlock",
              "text": "停泊",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Center"
            },
            {
              "type": "TextBlock",
              "text": "${dockCount}",
              "size": "ExtraLarge",
              "horizontalAlignment": "Center"
            }
          ]
        },
        {
          "type": "Column",
          "width": "1",
          "items": [
            {
              "type": "TextBlock",
              "text": "黑匣子",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Center"
            },
            {
              "type": "TextBlock",
              "text": "${blackboxCount}",
              "size": "ExtraLarge",
              "horizontalAlignment": "Center"
            }
          ]
        },
        {
          "type": "Column",
          "width": "1",
          "items": [
            {
              "type": "TextBlock",
              "text": "项目",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Center"
            },
            {
              "type": "TextBlock",
              "text": "${projectName}",
              "wrap": true,
              "maxLines": 1,
              "horizontalAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${statusLine}",
      "size": "Small",
      "isSubtle": true,
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "打开 NanoFlow",
      "verb": "open-app"
    },
    {
      "type": "Action.Execute",
      "title": "打开专注模式",
      "verb": "open-focus"
    }
  ]
}
